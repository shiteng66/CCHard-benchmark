{
  "version": "0.1.0",
  "tasks": [
    {
      "subtask": "T05_diagnosis",
      "instruction": "请列出最可能的主要诊断及必要的次要诊断，按临床重要性排序；仅依据病例资料作答，并标明仍需验证的不确定诊断。",
      "rubric": {
        "scale": [
          0,
          100
        ],
        "criteria": [
          {
            "name": "主要诊断准确性",
            "points": 40
          },
          {
            "name": "必要次要诊断覆盖",
            "points": 20
          },
          {
            "name": "排序与临床重要性",
            "points": 20
          },
          {
            "name": "术语规范与不确定性表达",
            "points": 10
          },
          {
            "name": "无病例外臆测",
            "points": 10
          }
        ],
        "critical_errors": [
          "遗漏危及生命的主要诊断",
          "把缺乏证据的诊断表述为已确诊",
          "编造病例外检查或病史"
        ]
      }
    },
    {
      "subtask": "T07_evidence",
      "instruction": "请识别最可能的诊断，并为每个诊断提取支持证据，按症状体征、实验室、影像/功能及其他证据分类；不得补充病例外事实。",
      "rubric": {
        "scale": [
          0,
          100
        ],
        "criteria": [
          {
            "name": "诊断与证据对应",
            "points": 30
          },
          {
            "name": "关键证据覆盖",
            "points": 30
          },
          {
            "name": "证据质量与分层",
            "points": 20
          },
          {
            "name": "重要阴性证据",
            "points": 10
          },
          {
            "name": "无无依据推断",
            "points": 10
          }
        ],
        "critical_errors": [
          "证据与诊断错配",
